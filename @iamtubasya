function post($url, $header, $data, $proxy=null){

    $ch = curl_init();

    curl_setopt_array($ch, [
        CURLOPT_URL => $url,
        CURLOPT_FOLLOWLOCATION => true,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_HTTPHEADER => $header,
        CURLOPT_POST => true,
        CURLOPT_POSTFIELDS => $data,
        CURLOPT_SSL_VERIFYPEER => false,
        CURLOPT_SSL_VERIFYHOST => false,
        CURLOPT_CONNECTTIMEOUT => 30,
        CURLOPT_TIMEOUT => 30,
        CURLOPT_ENCODING => '',
    ]);

    if($proxy){

        // format:
        // ip:port
        // user:pass@ip:port

        $parts = parse_url("http://".$proxy);

        curl_setopt($ch, CURLOPT_PROXY, $parts['host']);
        curl_setopt($ch, CURLOPT_PROXYPORT, $parts['port']);

        if(isset($parts['user']) && isset($parts['pass'])){
            curl_setopt(
                $ch,
                CURLOPT_PROXYUSERPWD,
                $parts['user'].':'.$parts['pass']
            );
        }

        // HTTP proxy
        curl_setopt($ch, CURLOPT_PROXYTYPE, CURLPROXY_HTTP);

        // paksa semua traffic lewat proxy
        curl_setopt($ch, CURLOPT_HTTPPROXYTUNNEL, true);
    }

    $result = curl_exec($ch);

    if(curl_errno($ch)){
        echo curl_error($ch);
    }

    curl_close($ch);

    return $result;
}

function get($url, $header=[], $proxy=null){

    $ch = curl_init();

    curl_setopt_array($ch, [
        CURLOPT_URL => $url,
        CURLOPT_FOLLOWLOCATION => true,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_HTTPHEADER => $header,
        CURLOPT_SSL_VERIFYPEER => false,
        CURLOPT_SSL_VERIFYHOST => false,
        CURLOPT_CONNECTTIMEOUT => 30,
        CURLOPT_TIMEOUT => 30,
        CURLOPT_ENCODING => '',
    ]);

    if($proxy){

        $parts = parse_url("http://".$proxy);

        curl_setopt($ch, CURLOPT_PROXY, $parts['host']);
        curl_setopt($ch, CURLOPT_PROXYPORT, $parts['port']);

        if(isset($parts['user']) && isset($parts['pass'])){
            curl_setopt(
                $ch,
                CURLOPT_PROXYUSERPWD,
                $parts['user'].':'.$parts['pass']
            );
        }

        curl_setopt($ch, CURLOPT_PROXYTYPE, CURLPROXY_HTTP);
        curl_setopt($ch, CURLOPT_HTTPPROXYTUNNEL, true);
    }

    $result = curl_exec($ch);

    if(curl_errno($ch)){
        echo curl_error($ch);
    }

    curl_close($ch);

    return $result;
}


